# ── Приложение ────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY_32CHARS!!

# ── Backend DB ─────────────────────────────────────────────────
BACKEND_DB_HOST=postgres_backend
BACKEND_DB_PORT=5432
BACKEND_DB_NAME=backend_db
BACKEND_DB_USER=backend_user
BACKEND_DB_PASSWORD=CHANGE_ME_BACKEND_PASS
BACKEND_DB_POOL_SIZE=10
BACKEND_DB_MAX_OVERFLOW=20

# ── ML DB ──────────────────────────────────────────────────────
ML_DB_HOST=postgres_ml
ML_DB_PORT=5432
ML_DB_NAME=ml_db
ML_DB_USER=ml_user
ML_DB_PASSWORD=CHANGE_ME_ML_PASS
ML_DB_POOL_SIZE=10
ML_DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ── Yandex GPT ─────────────────────────────────────────────────
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# ── Backend сервис ─────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# ── ML сервис ──────────────────────────────────────────────────
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8001
ML_SERVICE_WORKERS=2
ML_SERVICE_INTERNAL_URL=http://ml_service:8001

# ── Кэш эмбеддингов ────────────────────────────────────────────
EMBEDDINGS_CACHE_DIR=/app/cache/embeddings

# ── Ежедневные инсайты ─────────────────────────────────────────
INSIGHTS_CRON_HOUR=3
INSIGHTS_CRON_MINUTE=0
